# Production build overrides (used by `vite build`, mode=production).
# `.env` is still loaded for everything else (Firebase web config, VAPID key);
# this file only overrides the API base so production builds hit the live API.
# Local `npm run dev` keeps using `.env` (http://127.0.0.1:8000/api/).
VITE_API_URL=https://api.codelab.pk/public/api/
